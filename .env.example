# ── Banco de dados ─────────────────────────────────────────────────────────
# Dev local (SQLite via libSQL):
#   DATABASE_URL="file:./dev.db"
# Produção (Supabase Transaction Pooler — porta 6543):
#   DATABASE_URL="postgresql://postgres.[project]:[password]@aws-0-[region].pooler.supabase.com:6543/postgres?pgbouncer=true&connection_limit=1"
DATABASE_URL="file:./dev.db"

# ── NextAuth ────────────────────────────────────────────────────────────────
# Gere um valor seguro com: openssl rand -base64 32
NEXTAUTH_SECRET="sua-chave-secreta-minimo-32-caracteres"

# URL base da aplicação (sem barra final)
# Dev: http://localhost:3000
# Prod: https://tesouro-es.vercel.app
NEXTAUTH_URL="http://localhost:3000"
